<?xml version="1.0" encoding="UTF-8"?>

<VBox alignment="CENTER" spacing="10"
      xmlns="http://javafx.com/javafx/20"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.csc325_firebase_webview_auth.view.AuthController">

    <children>

        <Label text="User Authentication" style="-fx-font-size:20"/>

        <TextField fx:id="nameField" promptText="Full Name"/>

        <TextField fx:id="emailField" promptText="Email"/>

        <PasswordField fx:id="passwordField" promptText="Password"/>

        <HBox alignment="CENTER" spacing="10">

            <Button text="Register" onAction="#handleRegister"/>

            <Button text="Sign In" onAction="#handleSignIn"/>

        </HBox>

        <Label fx:id="statusLabel"/>

    </children>

</VBox>
